# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Optional Postgres database connection string (e.g. Neon serverless URL).
# If not set, a robust local in-memory SQL mock layer is used automatically.
DATABASE_URL=

# SMTP Server credentials (Optional — used for order notifications and admin OTP verification):
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
ADMIN_NOTIFICATION_EMAIL=

# Vercel Blob Read/Write token (Optional — used for local images uploads to cloud):
BLOB_READ_WRITE_TOKEN=
